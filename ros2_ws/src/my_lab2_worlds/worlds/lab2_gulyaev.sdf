<?xml version="1.0" encoding="utf-8"?>
<sdf version="1.9">
  <world name="lab2_gulyaev">
    <scene>
      <ambient>1 1 1 1</ambient>
      <background>0.8 0.8 0.9 1</background>
      <shadows>false</shadows>
    </scene>
    <physics type="ode">
      <max_step_size>0.003</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>

    <light type="directional" name="sun">
      <pose>0 0 10 0 -0.5 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground">
      <static>true</static>
      <link name="l">
        <collision name="c"><geometry><plane><size>20 20</size></plane></geometry></collision>
        <visual name="v"><geometry><plane><size>20 20</size></plane></geometry>
          <material><ambient>0.9 0.9 0.9 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- PERIMETER 12x12 -->
    <model name="w_north"><static>true</static><pose>0 6 1.25 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>12 0.2 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>12 0.2 2.5</size></box></geometry><material><ambient>1 1 1 1</ambient></material></visual></link></model>
    <model name="w_south"><static>true</static><pose>0 -6 1.25 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>12 0.2 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>12 0.2 2.5</size></box></geometry><material><ambient>1 1 1 1</ambient></material></visual></link></model>
    <model name="w_east"><static>true</static><pose>6 0 1.25 0 0 1.5708</pose><link name="l"><collision name="c"><geometry><box><size>12 0.2 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>12 0.2 2.5</size></box></geometry><material><ambient>1 1 1 1</ambient></material></visual></link></model>
    <model name="w_west"><static>true</static><pose>-6 0 1.25 0 0 1.5708</pose><link name="l"><collision name="c"><geometry><box><size>12 0.2 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>12 0.2 2.5</size></box></geometry><material><ambient>1 1 1 1</ambient></material></visual></link></model>

    <!-- WALL y=2: room1 top, gap at x=3..5 -->
    <model name="w5a"><static>true</static><pose>-2 2 1.25 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>8 0.2 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>8 0.2 2.5</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>
    <model name="w5b"><static>true</static><pose>5 2 1.25 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>2 0.2 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>2 0.2 2.5</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>

    <!-- WALL x=-2 vertical: rooms 2,3 left side, gap at y=0..1.5 -->
    <model name="w6a"><static>true</static><pose>-2 -4.5 1.25 0 0 1.5708</pose><link name="l"><collision name="c"><geometry><box><size>3 0.2 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>3 0.2 2.5</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>
    <model name="w6b"><static>true</static><pose>-2 -1 1.25 0 0 1.5708</pose><link name="l"><collision name="c"><geometry><box><size>2 0.2 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>2 0.2 2.5</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>

    <!-- WALL y=-2: splits room3 from corridor, gap at x=0..1.5 -->
    <model name="w7a"><static>true</static><pose>-4.5 -2 1.25 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>3 0.2 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>3 0.2 2.5</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>

    <!-- 10 OBJECTS -->
    <!-- Room 1 (top, y=2..6) -->
    <model name="table"><static>true</static><pose>-2 4 0.4 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>1.2 0.6 0.8</size></box></geometry></collision><visual name="v"><geometry><box><size>1.2 0.6 0.8</size></box></geometry><material><ambient>0.6 0.4 0.2 1</ambient></material></visual></link></model>
    <model name="chair1"><static>true</static><pose>-2.8 4 0.25 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.4 0.4 0.5</size></box></geometry></collision><visual name="v"><geometry><box><size>0.4 0.4 0.5</size></box></geometry><material><ambient>0.2 0.2 1 1</ambient></material></visual></link></model>
    <model name="chair2"><static>true</static><pose>-1.2 4 0.25 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.4 0.4 0.5</size></box></geometry></collision><visual name="v"><geometry><box><size>0.4 0.4 0.5</size></box></geometry><material><ambient>0.2 0.2 1 1</ambient></material></visual></link></model>

    <!-- Room 2 (left middle, x=-6..-2 y=-2..2) -->
    <model name="sofa"><static>true</static><pose>-4 0.5 0.4 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>1.5 0.7 0.8</size></box></geometry></collision><visual name="v"><geometry><box><size>1.5 0.7 0.8</size></box></geometry><material><ambient>0.9 0.1 0.1 1</ambient></material></visual></link></model>
    <model name="bookshelf"><static>true</static><pose>-5.5 0 1 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.3 1 2</size></box></geometry></collision><visual name="v"><geometry><box><size>0.3 1 2</size></box></geometry><material><ambient>0.5 0.3 0.1 1</ambient></material></visual></link></model>

    <!-- Room 3 (bottom left, x=-6..-2 y=-6..-2) -->
    <model name="bed"><static>true</static><pose>-4 -4 0.3 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>2 1.2 0.6</size></box></geometry></collision><visual name="v"><geometry><box><size>2 1.2 0.6</size></box></geometry><material><ambient>0.1 0.6 0.1 1</ambient></material></visual></link></model>
    <model name="nightstand"><static>true</static><pose>-5.5 -3.5 0.25 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision><visual name="v"><geometry><box><size>0.5 0.5 0.5</size></box></geometry><material><ambient>0.4 0.4 0.4 1</ambient></material></visual></link></model>

    <!-- Corridor (right side, x=-2..6, y=-6..2) -->
    <model name="sink"><static>true</static><pose>4 -5 0.5 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>1 0.6 1</size></box></geometry></collision><visual name="v"><geometry><box><size>1 0.6 1</size></box></geometry><material><ambient>0.7 0.7 0.8 1</ambient></material></visual></link></model>
    <model name="obstacle"><static>true</static><pose>2 -1 0.25 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision><visual name="v"><geometry><box><size>0.5 0.5 0.5</size></box></geometry><material><ambient>1 0.6 0 1</ambient></material></visual></link></model>
    <model name="plant"><static>true</static><pose>4 0 0.3 0 0 0</pose><link name="l"><collision name="c"><geometry><cylinder><radius>0.2</radius><length>0.6</length></cylinder></geometry></collision><visual name="v"><geometry><cylinder><radius>0.2</radius><length>0.6</length></cylinder></geometry><material><ambient>0 0.6 0 1</ambient></material></visual></link></model>

    <!-- ROBOT in corridor -->
    <model name="waffle_pi" canonical_link="base_link">
      <pose>1 -4.5 0.01 0 0 0</pose>
      <link name="base_link">
        <inertial><mass>1.8</mass><inertia><ixx>0.023</ixx><iyy>0.023</iyy><izz>0.032</izz></inertia></inertial>
        <collision name="c"><geometry><box><size>0.26 0.26 0.12</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.26 0.26 0.12</size></box></geometry><material><ambient>0.2 0.2 0.2 1</ambient></material></visual>
      </link>
      <link name="lidar_link">
        <pose>0 0 0.15 0 0 0</pose>
        <inertial><mass>0.12</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
        <visual name="v"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry><material><ambient>0.8 0 0 1</ambient></material></visual>
        <sensor name="lidar" type="gpu_lidar">
          <always_on>true</always_on>
          <update_rate>5</update_rate>
          <topic>scan</topic>
          <lidar>
            <scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>6.28</max_angle></horizontal></scan>
            <range><min>0.12</min><max>3.5</max><resolution>0.015</resolution></range>
          </lidar>
        </sensor>
      </link>
      <joint name="lidar_joint" type="fixed"><parent>base_link</parent><child>lidar_link</child></joint>
      <link name="left_wheel">
        <pose>0 0.14 0 -1.5708 0 0</pose>
        <inertial><mass>0.1</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
        <collision name="c"><geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry><surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction></surface></collision>
        <visual name="v"><geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
      </link>
      <joint name="left_wheel_joint" type="revolute"><parent>base_link</parent><child>left_wheel</child><axis><xyz>0 0 1</xyz></axis></joint>
      <link name="right_wheel">
        <pose>0 -0.14 0 -1.5708 0 0</pose>
        <inertial><mass>0.1</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
        <collision name="c"><geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry><surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction></surface></collision>
        <visual name="v"><geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
      </link>
      <joint name="right_wheel_joint" type="revolute"><parent>base_link</parent><child>right_wheel</child><axis><xyz>0 0 1</xyz></axis></joint>
      <link name="caster">
        <pose>-0.1 0 -0.015 0 0 0</pose>
        <inertial><mass>0.05</mass><inertia><ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.00001</izz></inertia></inertial>
        <collision name="c"><geometry><sphere><radius>0.018</radius></sphere></geometry><surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface></collision>
      </link>
      <joint name="caster_joint" type="fixed"><parent>base_link</parent><child>caster</child></joint>
      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.287</wheel_separation>
        <wheel_radius>0.033</wheel_radius>
        <odom_publish_frequency>30</odom_publish_frequency>
        <topic>cmd_vel</topic>
        <odom_topic>odom</odom_topic>
        <tf_topic>tf</tf_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
      </plugin>
      <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>
    </model>
  </world>
</sdf>
